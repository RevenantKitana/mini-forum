generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model audit_logs {
  id          Int         @id @default(autoincrement())
  user_id     Int
  action      AuditAction
  target_type AuditTarget
  target_id   Int?
  target_name String?
  old_value   String?
  new_value   String?
  ip_address  String?
  user_agent  String?
  created_at  DateTime    @default(now())
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([created_at])
  @@index([target_type, target_id])
  @@index([user_id])
}

model bookmarks {
  id         Int      @id @default(autoincrement())
  user_id    Int
  post_id    Int
  created_at DateTime @default(now())
  posts      posts    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@index([post_id])
  @@index([user_id])
}

model categories {
  id                 Int             @id @default(autoincrement())
  name               String
  slug               String          @unique
  description        String?
  color              String?
  sort_order         Int             @default(0)
  post_count         Int             @default(0)
  is_active          Boolean         @default(true)
  view_permission    PermissionLevel @default(ALL)
  post_permission    PermissionLevel @default(MEMBER)
  comment_permission PermissionLevel @default(MEMBER)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  posts              posts[]
}

model comments {
  id                                                  Int           @id @default(autoincrement())
  content                                             String
  author_id                                           Int
  post_id                                             Int
  parent_id                                           Int?
  quoted_comment_id                                   Int?
  upvote_count                                        Int           @default(0)
  downvote_count                                      Int           @default(0)
  status                                              CommentStatus @default(VISIBLE)
  is_edited                                           Boolean       @default(false)
  is_content_masked                                   Boolean       @default(false)
  created_at                                          DateTime      @default(now())
  updated_at                                          DateTime      @updatedAt
  users                                               users         @relation(fields: [author_id], references: [id])
  comments_comments_parent_idTocomments               comments?     @relation("comments_parent_idTocomments", fields: [parent_id], references: [id])
  other_comments_comments_parent_idTocomments         comments[]    @relation("comments_parent_idTocomments")
  posts                                               posts         @relation(fields: [post_id], references: [id], onDelete: Cascade)
  comments_comments_quoted_comment_idTocomments       comments?     @relation("comments_quoted_comment_idTocomments", fields: [quoted_comment_id], references: [id])
  other_comments_comments_quoted_comment_idTocomments comments[]    @relation("comments_quoted_comment_idTocomments")

  @@index([author_id])
  @@index([parent_id])
  @@index([post_id])
}

model notifications {
  id           Int              @id @default(autoincrement())
  user_id      Int
  type         NotificationType
  title        String
  content      String
  related_id   Int?
  related_type String?
  is_read      Boolean          @default(false)
  deleted_at   DateTime?
  created_at   DateTime         @default(now())
  users        users            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, deleted_at])
  @@index([user_id, is_read])
}

model post_tags {
  post_id Int
  tag_id  Int
  posts   posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tags    tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model posts {
  id             Int         @id @default(autoincrement())
  title          String
  slug           String      @unique
  content        String
  excerpt        String?
  author_id      Int
  category_id    Int
  view_count     Int         @default(0)
  upvote_count   Int         @default(0)
  downvote_count Int         @default(0)
  comment_count  Int         @default(0)
  status         PostStatus  @default(PUBLISHED)
  is_pinned      Boolean     @default(false)
  pin_type       PinType?
  pin_order      Int         @default(0)
  is_locked      Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  bookmarks      bookmarks[]
  comments       comments[]
  post_tags      post_tags[]
  users          users       @relation(fields: [author_id], references: [id])
  categories     categories  @relation(fields: [category_id], references: [id])

  @@index([author_id])
  @@index([category_id])
  @@index([created_at])
  @@index([is_pinned, pin_order])
  @@index([status])
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  expires_at DateTime
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
}

model reports {
  id                                Int          @id @default(autoincrement())
  reporter_id                       Int
  target_type                       ReportTarget
  target_id                         Int
  reason                            String
  description                       String?
  status                            ReportStatus @default(PENDING)
  reviewed_by                       Int?
  reviewed_at                       DateTime?
  review_note                       String?
  created_at                        DateTime     @default(now())
  updated_at                        DateTime
  users_reports_reporter_idTousers  users        @relation("reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: Cascade)
  users_reports_reviewed_byTousers  users?       @relation("reports_reviewed_byTousers", fields: [reviewed_by], references: [id])

  @@index([reporter_id])
  @@index([status])
  @@index([target_type, target_id])
}

model tags {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  description    String?
  usage_count    Int             @default(0)
  use_permission PermissionLevel @default(ALL)
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  post_tags      post_tags[]
}

model user_blocks {
  id                                   Int      @id @default(autoincrement())
  blocker_id                           Int
  blocked_id                           Int
  created_at                           DateTime @default(now())
  users_user_blocks_blocked_idTousers  users    @relation("user_blocks_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: Cascade)
  users_user_blocks_blocker_idTousers  users    @relation("user_blocks_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: Cascade)

  @@unique([blocker_id, blocked_id])
}

model users {
  id                                       Int              @id @default(autoincrement())
  email                                    String           @unique
  username                                 String           @unique
  password_hash                            String
  display_name                             String?
  avatar_url                               String?
  bio                                      String?
  date_of_birth                            DateTime?
  gender                                   String?
  role                                     Role             @default(MEMBER)
  reputation                               Int              @default(0)
  is_verified                              Boolean          @default(false)
  is_active                                Boolean          @default(true)
  last_active_at                           DateTime?
  username_changed_at                      DateTime?
  created_at                               DateTime         @default(now())
  updated_at                               DateTime         @updatedAt
  audit_logs                               audit_logs[]
  bookmarks                                bookmarks[]
  comments                                 comments[]
  notifications                            notifications[]
  posts                                    posts[]
  refresh_tokens                           refresh_tokens[]
  reports_reports_reporter_idTousers        reports[]        @relation("reports_reporter_idTousers")
  reports_reports_reviewed_byTousers        reports[]        @relation("reports_reviewed_byTousers")
  user_blocks_user_blocks_blocked_idTousers user_blocks[]    @relation("user_blocks_blocked_idTousers")
  user_blocks_user_blocks_blocker_idTousers user_blocks[]    @relation("user_blocks_blocker_idTousers")
  votes                                    votes[]
  user_content_context                     user_content_context?
}

model user_content_context {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  personality   Json
  last_posts    Json     @default("[]")
  last_comments Json     @default("[]")
  action_count  Int      @default(0)
  updated_at    DateTime @updatedAt
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model votes {
  id          Int        @id @default(autoincrement())
  user_id     Int
  target_type VoteTarget
  target_id   Int
  value       Int
  created_at  DateTime   @default(now())
  updated_at  DateTime
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, target_type, target_id])
  @@index([target_type, target_id])
  @@index([user_id])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PIN
  UNPIN
  LOCK
  UNLOCK
  HIDE
  SHOW
  BAN
  UNBAN
  ROLE_CHANGE
  VIEW_MASKED_CONTENT
}

enum AuditTarget {
  USER
  POST
  COMMENT
  CATEGORY
  TAG
  REPORT
  SETTINGS
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum NotificationType {
  COMMENT
  REPLY
  MENTION
  UPVOTE
  SYSTEM
}

enum PermissionLevel {
  ALL
  MEMBER
  MODERATOR
  ADMIN
}

enum PinType {
  GLOBAL
  CATEGORY
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTarget {
  USER
  POST
  COMMENT
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
  BOT
}

enum VoteTarget {
  POST
  COMMENT
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
}

model otp_tokens {
  id            Int        @id @default(autoincrement())
  email         String
  purpose       OtpPurpose @default(REGISTER)
  code          String     @db.VarChar(255)
  verification_token String @unique
  is_verified   Boolean    @default(false)
  verified_at   DateTime?
  attempts_made Int        @default(0)
  max_attempts  Int        @default(5)
  expires_at    DateTime
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@index([email])
  @@index([expires_at])
  @@index([verification_token])
}
