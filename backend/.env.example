# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_forum?schema=public"

# JWT — must be unique random strings, min 32 chars each
JWT_ACCESS_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URLs for CORS (comma-separated, no spaces)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Comment edit time limit in minutes (default: 30)
COMMENT_EDIT_TIME_LIMIT=30

# Email Service Configuration (Brevo SMTP)
# ⚠️  REQUIRED for OTP Registration and Password Reset Features
#
# Brevo Setup:
#   1. Sign up: https://www.brevo.com/
#   2. Go to Settings > SMTP & API > SMTP
#   3. Get your SMTP credentials
#
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_FROM_EMAIL=noreply@example.com
BREVO_FROM_NAME=Mini Forum

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_DELAY_SECONDS=60
