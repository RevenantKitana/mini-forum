# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_forum?schema=public"

# JWT — must be unique random strings, min 32 chars each
JWT_ACCESS_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URLs for CORS (comma-separated, no spaces)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Comment edit time limit in minutes (default: 30)
COMMENT_EDIT_TIME_LIMIT=30

# Email Service Configuration (SMTP)
# ⚠️  REQUIRED for OTP Registration and Password Reset Features
# 
# Gmail Setup:
#   1. Enable "Less secure app access" or use "App Password":
#      https://myaccount.google.com/apppasswords
#   2. Use your Gmail address and the generated app password
#
# Mailgun Setup:
#   1. Sign up: https://www.mailgun.com/
#   2. Get SMTP credentials from domain settings
#   3. SMTP_HOST: smtp.mailgun.org, SMTP_PORT: 587
#
# SendGrid Setup:
#   1. Sign up: https://sendgrid.com/
#   2. Create SMTP API key
#   3. SMTP_HOST: smtp.sendgrid.net, SMTP_PORT: 587
#   4. SMTP_USER: apikey, SMTP_PASS: your-api-key
#
# Custom/Other SMTP Server:
#   1. Get credentials from your email hosting provider
#   2. Update SMTP_HOST and SMTP_PORT accordingly
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Mini Forum

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_DELAY_SECONDS=60
