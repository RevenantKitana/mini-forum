{
  "name": "mini-forum-backend",
  "description": "Mini Forum Backend API - Node.js + Express + TypeScript + Prisma",
  "buildCommand": "npm ci && npx prisma generate && npm run build",
  "startCommand": "/app/docker-entrypoint.sh",
  "envVars": [
    {
      "key": "NODE_ENV",
      "value": "production",
      "description": "Node environment (must be production)"
    },
    {
      "key": "PORT",
      "value": "5000",
      "description": "Server port"
    },
    {
      "key": "DATABASE_URL",
      "description": "PostgreSQL connection string with SSL and connection pooling (e.g., postgresql://user:pass@host/db?schema=public&sslmode=require&connect_timeout=10&pool_size=5)"
    },
    {
      "key": "JWT_ACCESS_SECRET",
      "description": "JWT access token secret (generate with: openssl rand -base64 32)"
    },
    {
      "key": "JWT_REFRESH_SECRET",
      "description": "JWT refresh token secret (generate with: openssl rand -base64 32)"
    },
    {
      "key": "JWT_ACCESS_EXPIRES_IN",
      "value": "15m",
      "description": "JWT access token expiration time"
    },
    {
      "key": "JWT_REFRESH_EXPIRES_IN",
      "value": "7d",
      "description": "JWT refresh token expiration time"
    },
    {
      "key": "FRONTEND_URL",
      "description": "Frontend URL for CORS (comma-separated if multiple)"
    },
    {
      "key": "COMMENT_EDIT_TIME_LIMIT",
      "value": "5",
      "description": "Time limit in minutes for editing comments"
    },
    {
      "key": "BREVO_API_KEY",
      "description": "Brevo (Sendinblue) API key for email service"
    },
    {
      "key": "BREVO_FROM_EMAIL",
      "description": "Brevo sender email address"
    },
    {
      "key": "BREVO_FROM_NAME",
      "description": "Brevo sender display name"
    },
    {
      "key": "OTP_LENGTH",
      "value": "6",
      "description": "OTP code length"
    },
    {
      "key": "OTP_EXPIRATION_MINUTES",
      "value": "10",
      "description": "OTP expiration time in minutes"
    },
    {
      "key": "OTP_MAX_ATTEMPTS",
      "value": "5",
      "description": "Maximum OTP verification attempts"
    },
    {
      "key": "OTP_RESEND_DELAY_SECONDS",
      "value": "60",
      "description": "Delay before allowing OTP resend in seconds"
    },
    {
      "key": "IMAGEKIT_PUBLIC_KEY",
      "description": "ImageKit public API key"
    },
    {
      "key": "IMAGEKIT_PRIVATE_KEY",
      "description": "ImageKit private API key"
    },
    {
      "key": "IMAGEKIT_URL_ENDPOINT",
      "description": "ImageKit URL endpoint"
    },
    {
      "key": "REDIS_URL",
      "description": "Redis connection URL (for sessions/cache) - optional if using in-memory store"
    },
    {
      "key": "ADMIN_SECRET",
      "description": "Secret key for admin operations"
    },
    {
      "key": "EMAIL_SERVICE",
      "value": "noreply",
      "description": "Email service type (noreply, smtp, etc.)"
    },
    {
      "key": "LOG_LEVEL",
      "value": "info",
      "description": "Log level: error, warn, info, http, debug"
    }
  ]
}
