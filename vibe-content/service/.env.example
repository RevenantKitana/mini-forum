# Forum Backend
FORUM_API_URL=https://mini-forum-backend-kkxu.onrender.com/api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini_forum?schema=public

# LLM Providers — Phase 1 only needs GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Bot user password (must match what was used in seed)
BOT_PASSWORD=BotUser@123

# Scheduler
CRON_SCHEDULE=*/30 * * * *
BATCH_SIZE=1

# Limits
MAX_POSTS_PER_USER_DAY=3
MAX_COMMENTS_PER_USER_DAY=6
MAX_VOTES_PER_USER_DAY=15
DAILY_LLM_BUDGET_USD=0.50

# Provider
PROVIDER_TIMEOUT_MS=30000

# Service
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
