# Development Dockerfile for local testing/debugging
FROM node:20-alpine

WORKDIR /app

# Install development tools
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    openssl \
    openssl-dev

COPY package.json package-lock.json ./
RUN npm ci

# Copy Prisma schema and generate
COPY prisma ./prisma
RUN npx prisma generate

COPY tsconfig.json ./
COPY src ./src

EXPOSE 4000

# Use tsx for development (hot reload)
CMD ["npm", "run", "dev"]
