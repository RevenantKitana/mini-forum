# Production forum backend URL
FORUM_API_URL=https://api.mini-forum.com/api

# PostgreSQL connection string with SSL for production
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db.example.com:5432/mini_forum?schema=public&sslmode=require

# ─── LLM PROVIDERS ──────────────────────────────────────────────────────────
# Gemini API Key (Always required, Primary provider)
GEMINI_API_KEY=AIzaSy...

# Groq API Key (Fallback provider #1)
GROQ_API_KEY=gsk_...

# Cerebras API Key (Fallback provider #2)
CEREBRAS_API_KEY=

# ─── BOT CREDENTIALS ────────────────────────────────────────────────────────
# Bot user password (MUST match what was seeded in database)
# Generate with: openssl rand -base64 24
BOT_PASSWORD=CHANGE_ME_STRONG_BOT_PASSWORD

# ─── SCHEDULER ──────────────────────────────────────────────────────────────
# Cron schedule for content generation (every 30 minutes in production)
# Format: minute hour day-of-month month day-of-week
# Examples:
#   */30 * * * * → Every 30 minutes
#   0 * * * *   → Every hour
#   30 2 * * *  → Daily at 2:30 AM
CRON_SCHEDULE=*/30 * * * *

# Actions to generate per batch
# Recommendation: 1-2 in production (to avoid rate limits)
BATCH_SIZE=1

# ─── RATE LIMITS ────────────────────────────────────────────────────────────
# Daily limits per bot user (to maintain realism)
MAX_POSTS_PER_USER_DAY=3
MAX_COMMENTS_PER_USER_DAY=6
MAX_VOTES_PER_USER_DAY=15

# ─── PROVIDER CONFIGURATION ────────────────────────────────────────────────
# Timeout for LLM provider requests (milliseconds)
# Recommendation: 30000-60000ms in production
PROVIDER_TIMEOUT_MS=30000

# ─── SERVICE CONFIGURATION ──────────────────────────────────────────────────
# Port the service runs on
PORT=4000

# Node environment (MUST be production for optimizations)
NODE_ENV=production

# Log level: error, warn, info, http, debug
# Recommendation: info for production (use debug for troubleshooting)
LOG_LEVEL=info

# ════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
