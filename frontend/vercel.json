{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_IMAGE_KIT_URL": "@vite_image_kit_url",
    "VITE_IMAGE_KIT_PUBLIC_KEY": "@vite_image_kit_public_key"
  }
}
