# API Configuration
# ⚠️  REQUIRED for production builds
# For development: defaults to http://localhost:5000/api/v1 if not set
# For production: MUST be set to your backend API URL
VITE_API_URL=http://localhost:5000/api/v1

# Set to 'true' to use mock data (no backend required for UI dev)
# Set to 'false' when backend is running — DEFAULT for local dev
VITE_USE_MOCK_API=false
